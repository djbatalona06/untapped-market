{
  "name": "untapped-market",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "collect": "node scripts/collect.mjs",
    "validate:data": "node scripts/validate-data.mjs",
    "seed:data": "node scripts/dev/extract-data.mjs",
    "prebuild": "node scripts/validate-data.mjs && node scripts/validate-pnw.mjs",
    "validate:pnw": "node scripts/validate-pnw.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
