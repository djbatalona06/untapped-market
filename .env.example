# ── Supabase (Phase A auth + Phase B media) ────────────────────────────────
# Copy this file to `.env` and fill in values from your Supabase project:
#   Project Settings → API. Only the URL and the *anon* (public) key belong in
#   the browser. NEVER put the service_role / secret key in a VITE_ var — it is
#   shipped to every visitor.
#
# When these are unset the app runs in local "mock auth" mode and still builds.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Comma-separated emails granted admin UI access before any profile row has
# is_admin = true. Server-side RLS (public.is_admin()) is the real gate; this
# only reveals the /admin affordance in the client during bootstrap.
VITE_ADMIN_EMAILS=
